# API Configuration
# This value overrides app.json `expo.extra.apiBaseUrl` when present.
# EXPO_PUBLIC_API_BASE_URL=https://saifamily.sustaininsight.com

# Local development alternatives:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000          # Android emulator
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000         # iOS simulator
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_LOCAL_IP:4000     # Physical device on same network
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.18:8000
EXPO_PUBLIC_MIXPANEL_TOKEN=replace-with-token
EXPO_PUBLIC_MIXPANEL_SERVER_URL=https://api-in.mixpanel.com
EXPO_PUBLIC_ANALYTICS_ENABLED=true
