# API Configuration
# For development on simulators/emulators: Use localhost/10.0.2.2
# For development on physical devices: Use your machine's local network IP

# Get your local IP:
# macOS/Linux: ipconfig getifaddr en0
# Windows: ipconfig (look for IPv4 Address under your network adapter)

# Example values (adjust to your network):
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Alternative values:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.0.1:4000          # Physical device on same network
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000          # Android emulator
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000          # iOS simulator
