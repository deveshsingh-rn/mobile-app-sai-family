{
  "expo": {
    "name": "sai-family",
    "slug": "sai-family",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons.png",
    "scheme": "saifamily",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deveshrn.saifamily",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Sai Family to recognize your speech for search.",
        "NSMicrophoneUsageDescription": "Allow Sai Family to use the microphone for voice search.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/saibaba1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#b97813",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Sai Family to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow Sai Family to recognize your speech for search."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Sai Family to use your location to fill event and directory coordinates."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "http://192.168.1.9:8000/api",
      "router": {},
      "eas": {
        "projectId": "d751b428-eab5-47a0-8ed0-4782b79d0e40"
      }
    },
    "owner": "devesh-rn"
  }
}
