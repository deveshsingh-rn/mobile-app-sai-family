        {
          "name": "POST /api/experiences - Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Experience created\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.experience && json.experience.id) {",
                  "  pm.environment.set(\"experienceId\", json.experience.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{authorId}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "content",
                  "value": "Sai Baba helped our family during a difficult time. Sharing this leela with gratitude.",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "miracles",
                  "type": "text"
                },
                {
                  "key": "location",
                  "value": "Pune, Maharashtra",
                  "type": "text"
                },
                {
                  "key": "mediaFiles",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "mediaAttachments",
                  "value": "[{\"type\":\"image\",\"url\":\"https://example.com/leela-photo.jpg\"}]",
                  "type": "text",
                  "disabled": true
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/experiences",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "experiences"
              ]
            }
          },
          "response": []
        },
