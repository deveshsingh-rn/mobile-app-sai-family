              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "category",
                  "value": "miracles",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/experiences/search - Search Feed",
          "request": {
            "method": "GET",
            "header": [],
